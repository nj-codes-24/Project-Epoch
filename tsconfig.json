{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true
  },
  "include": [
    "packages/**/*",
    "trigger/**/*",
    "supabase/**/*"
  ],
  "exclude": [
    "node_modules",
    "apps/**/*"
  ]
}
